<Application x:Class="KeywordGuard.Pro.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="BgBrush" Color="#0D1117"/>
            <SolidColorBrush x:Key="PanelBrush" Color="#161B22"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#30363D"/>
            <SolidColorBrush x:Key="PrimaryBrush" Color="#00FFCC"/>
            <SolidColorBrush x:Key="TextBrush" Color="#E6EDF3"/>
            <SolidColorBrush x:Key="MutedTextBrush" Color="#8B949E"/>
            <SolidColorBrush x:Key="DangerBrush" Color="#DA3633"/>
            <SolidColorBrush x:Key="AggressiveBrush" Color="#FF6B6B"/>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="Background" Value="#0D1117"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Padding" Value="8"/>
                <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}"/>
            </Style>
            <Style TargetType="Button">
                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="Foreground" Value="#0D1117"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource AggressiveBrush}"/>
            </Style>
            <Style TargetType="ListBox">
                <Setter Property="Background" Value="#0D1117"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>