<Window x:Class="KeywordGuard.Pro.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeywordGuard Pro"
        Width="900"
        Height="720"
        Background="{StaticResource BgBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="KEYWORD GUARD PRO" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Hide"
                    Width="90"
                    Height="30"
                    Margin="10,0,0,0"
                    VerticalAlignment="Top"
                    Click="HideButton_Click"/>
        </Grid>

        <!-- TIMER PANEL -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Timer" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Tage" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBox Width="80" Text="{Binding Days, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanStartTimer}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Stunden" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBox Width="80" Text="{Binding Hours, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanStartTimer}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Minuten" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBox Width="80" Text="{Binding Minutes, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanStartTimer}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="Timer starten &amp; blockieren"
                            Margin="0,12,0,0"
                            Command="{Binding StartTimerCommand}"
                            IsEnabled="{Binding CanStartTimer}"
                            Height="36"
                            FontSize="14"/>
                    <TextBlock Text="{Binding CountdownText}"
                               Margin="0,10,0,0"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Visibility="{Binding CountdownVisible}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock Text="Hinweis" FontWeight="Bold"/>
                    <TextBlock Text="Hinzufügen ist immer erlaubt. Löschen ist gesperrt, solange der Timer läuft."
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- WORD LIST (VOLLE BREITE, kein URL-Feld mehr) -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Gesperrte Wörter" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,8">
                    <TextBox Width="400" Text="{Binding KeywordInput, UpdateSourceTrigger=PropertyChanged}" FontSize="14" />
                    <CheckBox Content="Aggressiv" 
                              IsChecked="{Binding IsAggressive}" 
                              VerticalAlignment="Center" 
                              Margin="12,0,0,0"
                              FontSize="14"
                              Foreground="{StaticResource AggressiveBrush}"
                              ToolTip="Aggressiv = Blockiert auch kombinierte Wörter (z.B. 'hallo' blockiert auch 'hallodu')"/>
                    <Button Content="Hinzufügen"
                            Margin="12,0,0,0"
                            Height="32"
                            FontSize="14"
                            Command="{Binding AddKeywordCommand}"/>
                </StackPanel>
                
                <TextBlock Grid.Row="2" Text="Normal = nur exaktes Wort | Aggressiv = auch Teil von anderen Wörtern" 
                           FontSize="11" 
                           Foreground="{StaticResource MutedTextBrush}" 
                           Margin="0,0,0,10"/>
                
                <!-- ScrollViewer + ListBox: unendlich viele Einträge, scrollbar -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <ListBox ItemsSource="{Binding KeywordItems}"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="14">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="6">
                                    <Button Content="X"
                                            Width="28"
                                            Height="28"
                                            Margin="8,0,0,0"
                                            DockPanel.Dock="Right"
                                            Command="{Binding DataContext.RemoveKeywordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding DataContext.CanDelete, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Background="{StaticResource DangerBrush}"
                                            Foreground="White"
                                            FontSize="14"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Value}" FontSize="15"/>
                                        <TextBlock Text="{Binding AggressiveText}" 
                                                   Foreground="{StaticResource AggressiveBrush}" 
                                                   FontWeight="Bold" 
                                                   Margin="8,0,0,0"
                                                   FontSize="13"/>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- FOOTER -->
        <TextBlock Grid.Row="3" Text="{Binding FooterText}" Foreground="{StaticResource MutedTextBrush}" Margin="0,12,0,0"/>
    </Grid>
</Window>